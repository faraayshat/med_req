rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - users can only read/write their own document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Reports collection - users can create and read their own reports
    match /reports/{reportId} {
      // Allow creation if the report's userId matches the authenticated user
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Allow read/update/delete only if the report belongs to the authenticated user
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
